SocksPort 0.0.0.0:9050
ControlPort 9051
CookieAuthentication 1
CookieAuthFileGroupReadable 1

# Wlasny DataDirectory w /tmp -- omija permissions na /var/lib/tor
DataDirectory /tmp/tor-data

# Foreground, logi na stdout zeby Railway je widzial
RunAsDaemon 0
Log notice stdout

# Wydajnosc
NumEntryGuards 8
CircuitBuildTimeout 30
LearnCircuitBuildTimeout 0
MaxCircuitDirtiness 600
